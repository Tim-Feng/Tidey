#!/usr/bin/env bash

tidey_tmux_resolve_env_var_from_pane_option() {
    env_name="$1"
    pane_option="$2"
    tmux_pane="${TMUX_PANE:-}"
    pane_value=""
    global_value=""

    if [ -z "$tmux_pane" ] || ! command -v tmux >/dev/null 2>&1; then
        return 0
    fi

    pane_value="$(tmux show-options -p -v -t "$tmux_pane" "$pane_option" 2>/dev/null || true)"
    if [ -n "$pane_value" ]; then
        export "$env_name=$pane_value"
        return 0
    fi

    global_value="$(tmux show-environment "$env_name" 2>/dev/null || tmux show-environment -g "$env_name" 2>/dev/null || true)"
    case "$global_value" in
        "$env_name="*)
            export "$env_name=${global_value#"$env_name="}"
            ;;
        "-$env_name")
            unset "$env_name"
            ;;
    esac
}

tidey_hydrate_tmux_pane_identity() {
    tidey_tmux_resolve_env_var_from_pane_option "TIDEY_WORKSPACE_ID" "@tidey_workspace_id"
    tidey_tmux_resolve_env_var_from_pane_option "TIDEY_PANEL_ID" "@tidey_panel_id"
}
