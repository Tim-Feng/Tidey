#!/usr/bin/env bash

set -euo pipefail

REGISTRY_ROOT="$HOME/Library/Application Support/Tidey Remote Bridge/agent-sessions/codex"
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
# shellcheck source=/dev/null
source "$HOOK_DIR/tidey-tmux-pane-identity"

json_escape() {
    local s="${1-}"
    s=${s//\\/\\\\}
    s=${s//\"/\\\"}
    s=${s//$'\n'/\\n}
    s=${s//$'\r'/\\r}
    s=${s//$'\t'/\\t}
    printf '%s' "$s"
}

tmux_pane_id_from_env() {
    if [[ -n "${TMUX_PANE:-}" ]]; then
        printf '%s' "$TMUX_PANE"
    fi
}

tmux_socket_path_from_env() {
    local tmux_env="${TMUX:-}"
    if [[ -n "$tmux_env" ]]; then
        printf '%s' "${tmux_env%%,*}"
    fi
}

write_registry_file() {
    local path="$1"
    local workspace_id="$2"
    local session_id="$3"
    local panel_id="$4"
    local pid="$5"
    local cwd="$6"
    local created_at="$7"
    local rollout_path="$8"
    local tmp_path=""
    local tmux_pane_id=""
    local tmux_socket_path=""
    local tmux_fields=""

    tmux_pane_id="$(tmux_pane_id_from_env)"
    tmux_socket_path="$(tmux_socket_path_from_env)"

    if [[ -n "$tmux_pane_id" ]]; then
        tmux_fields+=",\"tmux_pane_id\":\"$(json_escape "$tmux_pane_id")\""
    fi
    if [[ -n "$tmux_socket_path" ]]; then
        tmux_fields+=",\"tmux_socket_path\":\"$(json_escape "$tmux_socket_path")\""
    fi

    mkdir -p "$REGISTRY_ROOT"
    tmp_path="$(mktemp "$REGISTRY_ROOT/.codex-registry.XXXXXX")"
    {
        printf '{"version":1,"vendor":"codex","workspace_id":"%s","session_id":"%s","panel_id":"%s","pid":%s,"cwd":"%s","created_at":"%s","rollout_path":"%s","transcript_path":"%s"%s}\n' \
            "$(json_escape "$workspace_id")" \
            "$(json_escape "$session_id")" \
            "$(json_escape "$panel_id")" \
            "$pid" \
            "$(json_escape "$cwd")" \
            "$(json_escape "$created_at")" \
            "$(json_escape "$rollout_path")" \
            "$(json_escape "$rollout_path")" \
            "$tmux_fields" > "$tmp_path"
        mv -f "$tmp_path" "$path"
    } || {
        rm -f "$tmp_path"
        return 1
    }
}

shell_quote() {
    local s="${1-}"
    s=${s//\'/\'\\\'\'}
    printf "'%s'" "$s"
}

merge_tidey_hooks_into_overlay() {
    local real_codex_home="$1"
    local overlay_codex_home="$2"
    local dispatch_script="$3"
    local existing_hooks_path="$real_codex_home/hooks.json"
    local merged_hooks_path="$overlay_codex_home/hooks.json"
    local node_script=""

    node_script+='const fs = require("fs");'
    node_script+='const [existingPath, outputPath, dispatchPath] = process.argv.slice(1);'
    node_script+='const shellQuote = (s) => `'\''${String(s).replace(/'\''/g, `'\''\\'\'''\''`)}'\''`;'
    node_script+='let root = {};'
    node_script+='if (fs.existsSync(existingPath)) {'
    node_script+='  try { root = JSON.parse(fs.readFileSync(existingPath, "utf8")); } catch { root = {}; }'
    node_script+='}'
    node_script+='if (!root || typeof root !== "object") root = {};'
    node_script+='if (!root.hooks || typeof root.hooks !== "object") root.hooks = {};'
    node_script+='const entries = [["SessionStart","session-start"],["UserPromptSubmit","user-prompt-submit"],["Stop","stop"]];'
    node_script+='for (const [eventName, tideyEvent] of entries) {'
    node_script+='  if (!Array.isArray(root.hooks[eventName])) root.hooks[eventName] = [];'
    node_script+='  const command = `${shellQuote(dispatchPath)} ${tideyEvent}`;'
    node_script+='  const exists = root.hooks[eventName].some(group => Array.isArray(group?.hooks) && group.hooks.some(h => h?.type === "command" && h?.command === command));'
    node_script+='  if (!exists) root.hooks[eventName].push({ hooks: [{ type: "command", command, timeout: 10 }] });'
    node_script+='}'
    node_script+='fs.writeFileSync(outputPath, JSON.stringify(root, null, 2) + "\\n");'

    node -e "$node_script" "$existing_hooks_path" "$merged_hooks_path" "$dispatch_script"
}

merge_tidey_config_into_overlay() {
    local real_codex_home="$1"
    local overlay_codex_home="$2"
    local existing_config_path="$real_codex_home/config.toml"
    local merged_config_path="$overlay_codex_home/config.toml"

    python3 - "$existing_config_path" "$merged_config_path" <<'PY'
from pathlib import Path
import re
import sys

existing_path = Path(sys.argv[1])
output_path = Path(sys.argv[2])
text = existing_path.read_text() if existing_path.exists() else ""

if text and not text.endswith("\n"):
    text += "\n"

pattern = re.compile(r"(?ms)^\[features\]\n(?P<body>.*?)(?=^\[|\Z)")
match = pattern.search(text)
if match:
    body = match.group("body")
    if re.search(r"(?m)^codex_hooks\s*=\s*true\s*$", body):
        pass
    elif re.search(r"(?m)^codex_hooks\s*=\s*false\s*$", body):
        body = re.sub(r"(?m)^codex_hooks\s*=\s*false\s*$", "codex_hooks = true", body)
        text = text[:match.start("body")] + body + text[match.end("body"):]
    else:
        insertion = "" if body.endswith("\n") or body == "" else "\n"
        text = text[:match.end("body")] + insertion + "codex_hooks = true\n" + text[match.end("body"):]
else:
    if text and not text.endswith("\n\n"):
        text += "\n"
    text += "[features]\n"
    text += "codex_hooks = true\n"

if "suppress_unstable_features_warning" not in text:
    if text and not text.endswith("\n"):
        text += "\n"
    text += "suppress_unstable_features_warning = true\n"

output_path.write_text(text)
PY
}

prepare_codex_home_overlay() {
    local real_codex_home="$1"
    local overlay_codex_home="$2"
    local dispatch_script="$3"
    local entry=""
    local name=""

    mkdir -p "$overlay_codex_home"
    shopt -s dotglob nullglob
    for entry in "$real_codex_home"/*; do
        name="${entry##*/}"
        [[ "$name" == "." || "$name" == ".." || "$name" == "hooks.json" || "$name" == "config.toml" ]] && continue
        ln -s "$entry" "$overlay_codex_home/$name"
    done
    shopt -u dotglob nullglob

    merge_tidey_config_into_overlay "$real_codex_home" "$overlay_codex_home"
    merge_tidey_hooks_into_overlay "$real_codex_home" "$overlay_codex_home" "$dispatch_script"
}

resolve_real_codex_home() {
    local candidate="${CODEX_HOME:-$HOME/.codex}"
    local basename=""

    basename="$(basename "$candidate")"
    if [[ "$basename" == tidey-codex-home.* ]]; then
        printf '%s' "$HOME/.codex"
        return 0
    fi

    printf '%s' "$candidate"
}

find_real_codex() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/codex" ]] && printf '%s' "$d/codex" && return 0
    done
    return 1
}

rollout_for_pid() {
    local pid="$1"
    lsof -Fn -p "$pid" 2>/dev/null | sed -n 's/^n//p' | grep -E '/\.codex/sessions/.*/rollout-.*\.jsonl$' | tail -n 1
}

child_pids_for_pid() {
    local pid="$1"
    pgrep -P "$pid" 2>/dev/null || true
}

rollout_for_pid_tree() {
    local root_pid="$1"
    local queue=("$root_pid")
    local seen=" $root_pid "
    local pid=""
    local path=""
    local child=""

    while ((${#queue[@]} > 0)); do
        pid="${queue[0]}"
        queue=("${queue[@]:1}")

        path="$(rollout_for_pid "$pid" || true)"
        if [[ -n "$path" ]]; then
            printf '%s' "$path"
            return 0
        fi

        while IFS= read -r child; do
            [[ -n "$child" ]] || continue
            if [[ "$seen" != *" $child "* ]]; then
                seen+=" $child "
                queue+=("$child")
            fi
        done < <(child_pids_for_pid "$pid")
    done

    return 1
}

derive_session_id_from_rollout() {
    local path="$1"
    local basename="${path##*/}"
    local stem="${basename%.jsonl}"
    if [[ ${#stem} -ge 36 ]]; then
        printf '%s' "${stem: -36}"
    fi
}

monitor_rollout_and_registry() {
    local pid="$1"
    local workspace_id="$2"
    local panel_id="$3"
    local cwd="$4"
    local created_at="$5"
    local registry_file="${6:-}"
    local session_id="${7:-}"

    local rollout_path=""

    while kill -0 "$pid" 2>/dev/null; do
        local current_rollout_path=""
        local current_session_id=""
        local next_registry_file=""

        current_rollout_path="$(rollout_for_pid_tree "$pid" || true)"
        if [[ -n "$current_rollout_path" ]]; then
            current_session_id="$(derive_session_id_from_rollout "$current_rollout_path")"
        fi

        if [[ -n "$current_rollout_path" && -n "$workspace_id" && -n "$current_session_id" ]]; then
            next_registry_file="$REGISTRY_ROOT/codex-$current_session_id.json"
            if [[ -n "$registry_file" && "$registry_file" != "$next_registry_file" ]]; then
                rm -f "$registry_file"
            fi
            registry_file="$next_registry_file"
            rollout_path="$current_rollout_path"
            session_id="$current_session_id"
            write_registry_file "$registry_file" "$workspace_id" "$session_id" "$panel_id" "$pid" "$cwd" "$created_at" "$rollout_path"
        fi

        sleep 0.5
    done

    if [[ -n "$registry_file" ]]; then
        rm -f "$registry_file"
    fi
}

start_rollout_monitor_if_needed() {
    local pid="$1"
    local workspace_id="$2"
    local panel_id="$3"
    local cwd="$4"
    local created_at="$5"
    local initial_registry_file="${6:-}"
    local initial_session_id="${7:-}"

    if [[ -z "$workspace_id" ]]; then
        return 0
    fi

    monitor_rollout_and_registry "$pid" "$workspace_id" "$panel_id" "$cwd" "$created_at" "$initial_registry_file" "$initial_session_id" >/dev/null 2>&1 &
}

initial_session_id() {
    if command -v uuidgen >/dev/null 2>&1; then
        uuidgen | tr '[:upper:]' '[:lower:]'
        return 0
    fi
    python3 - <<'PY'
import uuid
print(str(uuid.uuid4()))
PY
}

main() {
    local real_codex=""
    local real_codex_home=""
    local overlay_codex_home=""
    local dispatch_script=""
    local created_at=""
    local session_id=""
    local registry_file=""

    real_codex="$(find_real_codex)" || { echo "Error: codex not found in PATH" >&2; exit 127; }
    tidey_hydrate_tmux_pane_identity

    if [[ -z "${TIDEY_SOCKET_PATH:-}" || ! -S "${TIDEY_SOCKET_PATH:-}" || -z "${TIDEY_WORKSPACE_ID:-}" ]]; then
        exec "$real_codex" "$@"
    fi

    real_codex_home="$(resolve_real_codex_home)"
    overlay_codex_home="$(mktemp -d "${TMPDIR:-/tmp}/tidey-codex-home.XXXXXX")"
    dispatch_script="$HOOK_DIR/codex-hook-dispatch"
    prepare_codex_home_overlay "$real_codex_home" "$overlay_codex_home" "$dispatch_script"

    created_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    session_id="$(initial_session_id)"
    registry_file="$REGISTRY_ROOT/codex-$session_id.json"
    write_registry_file "$registry_file" "$TIDEY_WORKSPACE_ID" "$session_id" "${TIDEY_PANEL_ID:-}" "$$" "$PWD" "$created_at" ""

    cleanup() {
        rm -rf "$overlay_codex_home"
    }

    trap cleanup EXIT

    start_rollout_monitor_if_needed "$$" "${TIDEY_WORKSPACE_ID:-}" "${TIDEY_PANEL_ID:-}" "$PWD" "$created_at" "$registry_file" "$session_id"

    if [[ -n "${TIDEY_SOCKET_PATH:-}" && -n "${TIDEY_WORKSPACE_ID:-}" ]]; then
        "$HOOK_DIR/tidey" codex-hook session-start || true
    fi

    exec env CODEX_HOME="$overlay_codex_home" "$real_codex" "$@"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
