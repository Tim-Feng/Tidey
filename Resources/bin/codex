#!/usr/bin/env bash

set -euo pipefail

REGISTRY_ROOT="$HOME/Library/Application Support/Tidey Remote Bridge/agent-sessions/codex"

json_escape() {
    local s="${1-}"
    s=${s//\\/\\\\}
    s=${s//\"/\\\"}
    s=${s//$'\n'/\\n}
    s=${s//$'\r'/\\r}
    s=${s//$'\t'/\\t}
    printf '%s' "$s"
}

write_registry_file() {
    local path="$1"
    local workspace_id="$2"
    local session_id="$3"
    local panel_id="$4"
    local pid="$5"
    local cwd="$6"
    local created_at="$7"
    local rollout_path="$8"
    local tmp_path=""

    mkdir -p "$REGISTRY_ROOT"
    tmp_path="$(mktemp "$REGISTRY_ROOT/.codex-registry.XXXXXX")"
    {
        printf '{"version":1,"vendor":"codex","workspace_id":"%s","session_id":"%s","panel_id":"%s","pid":%s,"cwd":"%s","created_at":"%s","rollout_path":"%s","transcript_path":"%s"}\n' \
            "$(json_escape "$workspace_id")" \
            "$(json_escape "$session_id")" \
            "$(json_escape "$panel_id")" \
            "$pid" \
            "$(json_escape "$cwd")" \
            "$(json_escape "$created_at")" \
            "$(json_escape "$rollout_path")" \
            "$(json_escape "$rollout_path")" > "$tmp_path"
        mv -f "$tmp_path" "$path"
    } || {
        rm -f "$tmp_path"
        return 1
    }
}

find_real_codex() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/codex" ]] && printf '%s' "$d/codex" && return 0
    done
    return 1
}

latest_rollout_snapshot() {
    local sessions_dir="$HOME/.codex/sessions"
    [[ -d "$sessions_dir" ]] || return 1

    find "$sessions_dir" -type f -name 'rollout-*.jsonl' -print 2>/dev/null | while IFS= read -r path; do
        [[ -n "$path" ]] || continue
        printf '%s\t%s\n' "$(stat -f '%m' "$path" 2>/dev/null || printf '0')" "$path"
    done | sort -nr | head -n 1 | cut -f2-
}

latest_rollout_file() {
    latest_rollout_snapshot | cut -f2-
}

rollout_for_pid() {
    local pid="$1"
    lsof -Fn -p "$pid" 2>/dev/null | sed -n 's/^n//p' | grep -E '/\.codex/sessions/.*/rollout-.*\.jsonl$' | tail -n 1
}

derive_session_id_from_rollout() {
    local path="$1"
    local basename="${path##*/}"
    local stem="${basename%.jsonl}"
    if [[ ${#stem} -ge 36 ]]; then
        printf '%s' "${stem: -36}"
    fi
}

monitor_rollout_and_registry() {
    local pid="$1"
    local previous_latest_path="$2"
    local previous_latest_mtime="$3"
    local workspace_id="$4"
    local panel_id="$5"
    local cwd="$6"
    local created_at="$7"

    local registry_file=""
    local rollout_path=""
    local session_id=""
    local latest_snapshot=""
    local latest_mtime=""
    local latest_path=""

    while kill -0 "$pid" 2>/dev/null; do
        if [[ -z "$rollout_path" ]]; then
            rollout_path="$(rollout_for_pid "$pid" || true)"
        fi
        if [[ -z "$rollout_path" ]]; then
            latest_snapshot="$(latest_rollout_snapshot || true)"
            if [[ -n "$latest_snapshot" ]]; then
                latest_mtime="${latest_snapshot%%$'\t'*}"
                latest_path="${latest_snapshot#*$'\t'}"
                if [[ "$latest_path" != "$previous_latest_path" || "$latest_mtime" != "$previous_latest_mtime" ]]; then
                    rollout_path="$latest_path"
                fi
            fi
        fi

        if [[ -n "$rollout_path" && -z "$registry_file" ]]; then
            session_id="$(derive_session_id_from_rollout "$rollout_path")"
            if [[ -n "$workspace_id" && -n "$session_id" ]]; then
                registry_file="$REGISTRY_ROOT/codex-$session_id.json"
                write_registry_file "$registry_file" "$workspace_id" "$session_id" "$panel_id" "$pid" "$cwd" "$created_at" "$rollout_path"
            fi
        fi

        sleep 0.5
    done

    if [[ -n "$registry_file" ]]; then
        rm -f "$registry_file"
    fi
}

REAL_CODEX="$(find_real_codex)" || { echo "Error: codex not found in PATH" >&2; exit 127; }

if [[ -z "${TIDEY_SOCKET_PATH:-}" || ! -S "${TIDEY_SOCKET_PATH:-}" || -z "${TIDEY_WORKSPACE_ID:-}" ]]; then
    exec "$REAL_CODEX" "$@"
fi

PREVIOUS_SNAPSHOT="$(latest_rollout_snapshot || true)"
PREVIOUS_MTIME="${PREVIOUS_SNAPSHOT%%$'\t'*}"
PREVIOUS_PATH="${PREVIOUS_SNAPSHOT#*$'\t'}"
if [[ "$PREVIOUS_PATH" == "$PREVIOUS_SNAPSHOT" ]]; then
    PREVIOUS_PATH=""
    PREVIOUS_MTIME=""
fi
CREATED_AT="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
monitor_rollout_and_registry "$$" "$PREVIOUS_PATH" "$PREVIOUS_MTIME" "$TIDEY_WORKSPACE_ID" "${TIDEY_PANEL_ID:-}" "$PWD" "$CREATED_AT" &

exec "$REAL_CODEX" "$@"
