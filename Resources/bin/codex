#!/usr/bin/env bash

set -euo pipefail

REGISTRY_ROOT="$HOME/Library/Application Support/Tidey Remote Bridge/agent-sessions/codex"
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
# shellcheck source=/dev/null
source "$HOOK_DIR/tidey-tmux-pane-identity"

json_escape() {
    local s="${1-}"
    s=${s//\\/\\\\}
    s=${s//\"/\\\"}
    s=${s//$'\n'/\\n}
    s=${s//$'\r'/\\r}
    s=${s//$'\t'/\\t}
    printf '%s' "$s"
}

tmux_pane_id_from_env() {
    if [[ -n "${TMUX_PANE:-}" ]]; then
        printf '%s' "$TMUX_PANE"
    fi
}

tmux_socket_path_from_env() {
    local tmux_env="${TMUX:-}"
    if [[ -n "$tmux_env" ]]; then
        printf '%s' "${tmux_env%%,*}"
    fi
}

write_registry_file() {
    local path="$1"
    local workspace_id="$2"
    local session_id="$3"
    local panel_id="$4"
    local pid="$5"
    local cwd="$6"
    local created_at="$7"
    local rollout_path="$8"
    local tmp_path=""
    local tmux_pane_id=""
    local tmux_socket_path=""
    local tmux_fields=""

    tmux_pane_id="$(tmux_pane_id_from_env)"
    tmux_socket_path="$(tmux_socket_path_from_env)"

    if [[ -n "$tmux_pane_id" ]]; then
        tmux_fields+=",\"tmux_pane_id\":\"$(json_escape "$tmux_pane_id")\""
    fi
    if [[ -n "$tmux_socket_path" ]]; then
        tmux_fields+=",\"tmux_socket_path\":\"$(json_escape "$tmux_socket_path")\""
    fi

    mkdir -p "$REGISTRY_ROOT"
    tmp_path="$(mktemp "$REGISTRY_ROOT/.codex-registry.XXXXXX")"
    {
        printf '{"version":1,"vendor":"codex","workspace_id":"%s","session_id":"%s","panel_id":"%s","pid":%s,"cwd":"%s","created_at":"%s","rollout_path":"%s","transcript_path":"%s"%s}\n' \
            "$(json_escape "$workspace_id")" \
            "$(json_escape "$session_id")" \
            "$(json_escape "$panel_id")" \
            "$pid" \
            "$(json_escape "$cwd")" \
            "$(json_escape "$created_at")" \
            "$(json_escape "$rollout_path")" \
            "$(json_escape "$rollout_path")" \
            "$tmux_fields" > "$tmp_path"
        mv -f "$tmp_path" "$path"
    } || {
        rm -f "$tmp_path"
        return 1
    }
}

shell_quote() {
    local s="${1-}"
    s=${s//\'/\'\\\'\'}
    printf "'%s'" "$s"
}

toml_escape() {
    json_escape "$1"
}

codex_profile_component() {
    local raw="$1"
    local sanitized=""

    sanitized="$(printf '%s' "$raw" | LC_ALL=C tr -c 'A-Za-z0-9_-' '-')"
    sanitized="${sanitized##-}"
    sanitized="${sanitized%%-}"
    if [[ -n "$sanitized" ]]; then
        printf '%s' "$sanitized"
    else
        printf 'default'
    fi
}

tmux_session_name_from_env() {
    if [[ -n "${TMUX_PANE:-}" ]]; then
        tmux display-message -p -t "$TMUX_PANE" "#{session_name}" 2>/dev/null || true
    fi
}

stable_codex_profile_name() {
    local identity="${1:-}"

    printf 'tidey-codex-%s' "$(codex_profile_component "$identity")"
}

stable_codex_sqlite_home() {
    local real_codex_home="$1"
    local identity="${2:-}"

    if [[ -n "$identity" ]]; then
        printf '%s/.tmp/tidey-codex-sqlite-%s' "$real_codex_home" "$(codex_profile_component "$identity")"
    else
        printf '%s/.tmp/tidey-codex-sqlite-default' "$real_codex_home"
    fi
}

merge_tidey_hooks_into_user_hooks() {
    local real_codex_home="$1"
    local dispatch_script="$2"
    local hooks_path="$real_codex_home/hooks.json"
    local tmp_path=""

    mkdir -p "$real_codex_home"
    tmp_path="$(mktemp "$real_codex_home/.hooks.XXXXXX")"

    python3 - "$hooks_path" "$tmp_path" "$dispatch_script" <<'PY'
from pathlib import Path
import json
import os
import sys

hooks_path = Path(sys.argv[1])
tmp_path = Path(sys.argv[2])
dispatch_script = sys.argv[3]

def shell_quote(value: str) -> str:
    return "'" + value.replace("'", "'\\''") + "'"

root = {}
if hooks_path.exists():
    try:
        root = json.loads(hooks_path.read_text())
    except Exception:
        tmp_path.unlink(missing_ok=True)
        raise SystemExit(0)

if not isinstance(root, dict):
    root = {}

hooks = root.setdefault("hooks", {})
if not isinstance(hooks, dict):
    hooks = {}
    root["hooks"] = hooks

entries = [
    ("SessionStart", "session-start"),
    ("UserPromptSubmit", "user-prompt-submit"),
    ("Stop", "stop"),
]
changed = False

for event_name, tidey_event in entries:
    groups = hooks.setdefault(event_name, [])
    if not isinstance(groups, list):
        groups = []
        hooks[event_name] = groups
        changed = True

    command = f"{shell_quote(dispatch_script)} {tidey_event}"
    exists = False
    for group in groups:
        if not isinstance(group, dict):
            continue
        handlers = group.get("hooks")
        if not isinstance(handlers, list):
            continue
        for handler in handlers:
            if (
                isinstance(handler, dict)
                and handler.get("type") == "command"
                and handler.get("command") == command
            ):
                exists = True
                break
        if exists:
            break

    if not exists:
        groups.append({"hooks": [{"type": "command", "command": command, "timeout": 10}]})
        changed = True

if changed or not hooks_path.exists():
    tmp_path.write_text(json.dumps(root, indent=2) + "\n")
    os.replace(tmp_path, hooks_path)
else:
    tmp_path.unlink(missing_ok=True)
PY
}

write_tidey_profile_config() {
    local real_codex_home="$1"
    local profile_name="$2"
    local sqlite_home="$3"
    local dispatch_script="$4"
    local profile_path="$real_codex_home/$profile_name.config.toml"
    local hooks_path="$real_codex_home/hooks.json"
    local tmp_path=""

    mkdir -p "$real_codex_home" "$sqlite_home"
    tmp_path="$(mktemp "$real_codex_home/.${profile_name}.config.XXXXXX")"

    python3 - "$tmp_path" "$profile_path" "$sqlite_home" "$hooks_path" "$dispatch_script" <<'PY' && mv -f "$tmp_path" "$profile_path" || {
from pathlib import Path
import hashlib
import json
import sys

tmp_path = Path(sys.argv[1])
profile_path = sys.argv[2]
sqlite_home = sys.argv[3]
hooks_path = Path(sys.argv[4])
dispatch_script = sys.argv[5]

def toml_string(value: str) -> str:
    return json.dumps(value)

def shell_quote(value: str) -> str:
    return "'" + value.replace("'", "'\\''") + "'"

def hook_hash(event_key: str, command: str, timeout: int) -> str:
    identity = {
        "event_name": event_key,
        "hooks": [
            {
                "async": False,
                "command": command,
                "timeout": timeout,
                "type": "command",
            }
        ],
    }
    payload = json.dumps(identity, sort_keys=True, separators=(",", ":")).encode()
    return "sha256:" + hashlib.sha256(payload).hexdigest()

event_key_by_name = {
    "SessionStart": "session_start",
    "UserPromptSubmit": "user_prompt_submit",
    "Stop": "stop",
}
event_suffix_by_name = {
    "SessionStart": "session-start",
    "UserPromptSubmit": "user-prompt-submit",
    "Stop": "stop",
}

try:
    root = json.loads(hooks_path.read_text())
except Exception:
    root = {}

hooks = root.get("hooks", {}) if isinstance(root, dict) else {}
state_entries = []
for event_name, event_key in event_key_by_name.items():
    groups = hooks.get(event_name, [])
    if not isinstance(groups, list):
        continue
    expected_command = f"{shell_quote(dispatch_script)} {event_suffix_by_name[event_name]}"
    for group_index, group in enumerate(groups):
        if not isinstance(group, dict):
            continue
        handlers = group.get("hooks", [])
        if not isinstance(handlers, list):
            continue
        for handler_index, handler in enumerate(handlers):
            if not isinstance(handler, dict):
                continue
            if handler.get("type") != "command" or handler.get("command") != expected_command:
                continue
            timeout = int(handler.get("timeout", 0) or 0)
            state_key = f"{hooks_path}:{event_key}:{group_index}:{handler_index}"
            state_entries.append((state_key, hook_hash(event_key, expected_command, timeout)))

lines = [
    f"sqlite_home = {toml_string(sqlite_home)}",
    "suppress_unstable_features_warning = true",
    "",
    "[features]",
    "hooks = true",
    "",
]
for state_key, trusted_hash in state_entries:
    lines.extend([
        f"[hooks.state.{toml_string(state_key)}]",
        f"trusted_hash = {toml_string(trusted_hash)}",
        "",
    ])

tmp_path.write_text("\n".join(lines).rstrip() + "\n")
PY
        rm -f "$tmp_path"
        return 1
    }
}

resolve_real_codex_home() {
    local candidate="${CODEX_HOME:-$HOME/.codex}"
    local basename=""

    basename="$(basename "$candidate")"
    if [[ "$basename" == tidey-codex-home* ]]; then
        printf '%s' "$HOME/.codex"
        return 0
    fi

    printf '%s' "$candidate"
}

find_real_codex() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/codex" ]] && printf '%s' "$d/codex" && return 0
    done
    return 1
}

rollout_for_pid() {
    local pid="$1"
    lsof -Fn -p "$pid" 2>/dev/null | sed -n 's/^n//p' | grep -E '/\.codex/sessions/.*/rollout-.*\.jsonl$' | tail -n 1
}

child_pids_for_pid() {
    local pid="$1"
    pgrep -P "$pid" 2>/dev/null || true
}

rollout_for_pid_tree() {
    local root_pid="$1"
    local queue=("$root_pid")
    local seen=" $root_pid "
    local pid=""
    local path=""
    local child=""

    while ((${#queue[@]} > 0)); do
        pid="${queue[0]}"
        queue=("${queue[@]:1}")

        path="$(rollout_for_pid "$pid" || true)"
        if [[ -n "$path" ]]; then
            printf '%s' "$path"
            return 0
        fi

        while IFS= read -r child; do
            [[ -n "$child" ]] || continue
            if [[ "$seen" != *" $child "* ]]; then
                seen+=" $child "
                queue+=("$child")
            fi
        done < <(child_pids_for_pid "$pid")
    done

    return 1
}

derive_session_id_from_rollout() {
    local path="$1"
    local basename="${path##*/}"
    local stem="${basename%.jsonl}"
    if [[ ${#stem} -ge 36 ]]; then
        printf '%s' "${stem: -36}"
    fi
}

monitor_rollout_and_registry() {
    local pid="$1"
    local workspace_id="$2"
    local panel_id="$3"
    local cwd="$4"
    local created_at="$5"
    local registry_file="${6:-}"
    local session_id="${7:-}"

    local rollout_path=""

    while kill -0 "$pid" 2>/dev/null; do
        local current_rollout_path=""
        local current_session_id=""
        local next_registry_file=""

        current_rollout_path="$(rollout_for_pid_tree "$pid" || true)"
        if [[ -n "$current_rollout_path" ]]; then
            current_session_id="$(derive_session_id_from_rollout "$current_rollout_path")"
        fi

        if [[ -n "$current_rollout_path" && -n "$workspace_id" && -n "$current_session_id" ]]; then
            next_registry_file="$REGISTRY_ROOT/codex-$current_session_id.json"
            if [[ -n "$registry_file" && "$registry_file" != "$next_registry_file" ]]; then
                rm -f "$registry_file"
            fi
            registry_file="$next_registry_file"
            rollout_path="$current_rollout_path"
            session_id="$current_session_id"
            write_registry_file "$registry_file" "$workspace_id" "$session_id" "$panel_id" "$pid" "$cwd" "$created_at" "$rollout_path"
        fi

        sleep 0.5
    done

    if [[ -n "$registry_file" ]]; then
        rm -f "$registry_file"
    fi
}

start_rollout_monitor_if_needed() {
    local pid="$1"
    local workspace_id="$2"
    local panel_id="$3"
    local cwd="$4"
    local created_at="$5"
    local initial_registry_file="${6:-}"
    local initial_session_id="${7:-}"

    if [[ -z "$workspace_id" ]]; then
        return 0
    fi

    monitor_rollout_and_registry "$pid" "$workspace_id" "$panel_id" "$cwd" "$created_at" "$initial_registry_file" "$initial_session_id" >/dev/null 2>&1 &
}

initial_session_id() {
    if command -v uuidgen >/dev/null 2>&1; then
        uuidgen | tr '[:upper:]' '[:lower:]'
        return 0
    fi
    python3 - <<'PY'
import uuid
print(str(uuid.uuid4()))
PY
}

main() {
    local real_codex=""
    local real_codex_home=""
    local profile_identity=""
    local profile_name=""
    local sqlite_home=""
    local dispatch_script=""
    local created_at=""
    local session_id=""
    local registry_file=""

    real_codex="$(find_real_codex)" || { echo "Error: codex not found in PATH" >&2; exit 127; }
    tidey_hydrate_tmux_pane_identity

    if [[ -z "${TIDEY_SOCKET_PATH:-}" || ! -S "${TIDEY_SOCKET_PATH:-}" || -z "${TIDEY_WORKSPACE_ID:-}" ]]; then
        exec "$real_codex" "$@"
    fi

    real_codex_home="$(resolve_real_codex_home)"
    profile_identity="$(tmux_session_name_from_env)"
    profile_name="$(stable_codex_profile_name "$profile_identity")"
    sqlite_home="$(stable_codex_sqlite_home "$real_codex_home" "$profile_identity")"
    dispatch_script="$HOOK_DIR/codex-hook-dispatch"
    merge_tidey_hooks_into_user_hooks "$real_codex_home" "$dispatch_script"
    write_tidey_profile_config "$real_codex_home" "$profile_name" "$sqlite_home" "$dispatch_script"

    created_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    session_id="$(initial_session_id)"
    registry_file="$REGISTRY_ROOT/codex-$session_id.json"
    write_registry_file "$registry_file" "$TIDEY_WORKSPACE_ID" "$session_id" "${TIDEY_PANEL_ID:-}" "$$" "$PWD" "$created_at" ""

    start_rollout_monitor_if_needed "$$" "${TIDEY_WORKSPACE_ID:-}" "${TIDEY_PANEL_ID:-}" "$PWD" "$created_at" "$registry_file" "$session_id"

    if [[ -n "${TIDEY_SOCKET_PATH:-}" && -n "${TIDEY_WORKSPACE_ID:-}" ]]; then
        "$HOOK_DIR/tidey" codex-hook session-start || true
    fi

    exec env CODEX_HOME="$real_codex_home" "$real_codex" --profile-v2 "$profile_name" "$@"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
