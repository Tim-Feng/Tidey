#!/usr/bin/env bash

set -euo pipefail

EVENT="${1:-}"
PAYLOAD_JSON="${2:-}"
LOG_PATH="${TMPDIR:-/tmp}/codex-hook-events.log"

if [[ -z "$EVENT" ]]; then
    exit 0
fi

{
    printf '%s pid=%s event=%s workspace=%s panel=%s payload=%s\n' \
        "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        "$$" \
        "$EVENT" \
        "${TIDEY_WORKSPACE_ID:-}" \
        "${TIDEY_PANEL_ID:-}" \
        "${PAYLOAD_JSON:-}"
} >> "$LOG_PATH" 2>/dev/null || true

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
TIDEY_BIN="$HOOK_DIR/tidey"

if [[ -n "${TMUX:-}" ]] && command -v tmux >/dev/null 2>&1; then
    tmux_workspace="$(tmux show-environment TIDEY_WORKSPACE_ID 2>/dev/null || tmux show-environment -g TIDEY_WORKSPACE_ID 2>/dev/null || true)"
    case "$tmux_workspace" in
        TIDEY_WORKSPACE_ID=*) export TIDEY_WORKSPACE_ID="${tmux_workspace#TIDEY_WORKSPACE_ID=}" ;;
        -TIDEY_WORKSPACE_ID) unset TIDEY_WORKSPACE_ID ;;
    esac

    tmux_panel="$(tmux show-environment TIDEY_PANEL_ID 2>/dev/null || tmux show-environment -g TIDEY_PANEL_ID 2>/dev/null || true)"
    case "$tmux_panel" in
        TIDEY_PANEL_ID=*) export TIDEY_PANEL_ID="${tmux_panel#TIDEY_PANEL_ID=}" ;;
        -TIDEY_PANEL_ID) unset TIDEY_PANEL_ID ;;
    esac
fi

if [[ -n "$PAYLOAD_JSON" ]]; then
    {
        printf '%s pid=%s dispatch=tidey workspace=%s panel=%s\n' \
            "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            "$$" \
            "${TIDEY_WORKSPACE_ID:-}" \
            "${TIDEY_PANEL_ID:-}"
    } >> "$LOG_PATH" 2>/dev/null || true
    exec "$TIDEY_BIN" codex-hook "$EVENT" "$PAYLOAD_JSON"
fi

{
    printf '%s pid=%s dispatch=tidey workspace=%s panel=%s\n' \
        "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        "$$" \
        "${TIDEY_WORKSPACE_ID:-}" \
        "${TIDEY_PANEL_ID:-}"
} >> "$LOG_PATH" 2>/dev/null || true

exec "$TIDEY_BIN" codex-hook "$EVENT"
