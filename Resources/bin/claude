#!/usr/bin/env bash
# Tidey claude wrapper — injects hooks for notification and status tracking.
#
# When running inside a Tidey terminal (TIDEY_SOCKET_PATH is set and live),
# this wrapper intercepts `claude` invocations to inject --settings with hooks
# so that Claude Code events fire back into Tidey for notifications/status.
# Outside Tidey, it passes through to the real claude binary unchanged.

set -euo pipefail

# Find the real claude binary, skipping our own directory.
find_real_claude() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/claude" ]] && printf '%s' "$d/claude" && return 0
    done
    return 1
}

# Pass through if not in a Tidey terminal or socket is unavailable.
if [[ -z "${TIDEY_SOCKET_PATH:-}" || ! -S "${TIDEY_SOCKET_PATH:-}" ]]; then
    REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }
    exec "$REAL_CLAUDE" "$@"
fi

REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }

# Pass through subcommands that don't support hooks.
case "${1:-}" in
    mcp|config|api-key) exec "$REAL_CLAUDE" "$@" ;;
esac

# Check if the user already specified a session/resume flag.
SKIP_SESSION_ID=false
for arg in "$@"; do
    case "$arg" in
        --resume|--resume=*|-r|--session-id|--session-id=*|--continue|-c)
            SKIP_SESSION_ID=true
            break
            ;;
    esac
done

# Build hooks settings JSON.
# Claude Code merges --settings additively with the user's own settings.json.
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
HOOKS_JSON='{"hooks":{"SessionStart":[{"matcher":"","hooks":[{"type":"command","command":"'"$HOOK_DIR"'/tidey claude-hook session-start","timeout":10}]}],"Notification":[{"matcher":"","hooks":[{"type":"command","command":"'"$HOOK_DIR"'/tidey claude-hook notification","timeout":10}]}],"Stop":[{"matcher":"","hooks":[{"type":"command","command":"'"$HOOK_DIR"'/tidey claude-hook stop","timeout":10}]}],"SessionEnd":[{"matcher":"","hooks":[{"type":"command","command":"'"$HOOK_DIR"'/tidey claude-hook session-end","timeout":1}]}],"UserPromptSubmit":[{"matcher":"","hooks":[{"type":"command","command":"'"$HOOK_DIR"'/tidey claude-hook prompt-submit","timeout":10}]}]}}'

if [[ "$SKIP_SESSION_ID" == true ]]; then
    exec "$REAL_CLAUDE" --settings "$HOOKS_JSON" "$@"
else
    SESSION_ID="$(uuidgen | tr '[:upper:]' '[:lower:]')"
    exec "$REAL_CLAUDE" --session-id "$SESSION_ID" --settings "$HOOKS_JSON" "$@"
fi
