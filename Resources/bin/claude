#!/usr/bin/env bash
# Tidey claude wrapper — injects hooks for notification and status tracking.
#
# When running inside a Tidey terminal (TIDEY_SOCKET_PATH is set and live),
# this wrapper intercepts `claude` invocations to inject --settings with hooks
# so that Claude Code events fire back into Tidey for notifications/status.
# Outside Tidey, it passes through to the real claude binary unchanged.

set -euo pipefail

REGISTRY_ROOT="$HOME/Library/Application Support/Tidey Remote Bridge/agent-sessions/claude"
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
source "$HOOK_DIR/tidey-tmux-pane-identity"

json_escape() {
    local s="${1-}"
    s=${s//\\/\\\\}
    s=${s//\"/\\\"}
    s=${s//$'\n'/\\n}
    s=${s//$'\r'/\\r}
    s=${s//$'\t'/\\t}
    printf '%s' "$s"
}

tmux_pane_id_from_env() {
    if [[ -n "${TMUX_PANE:-}" ]]; then
        printf '%s' "$TMUX_PANE"
    fi
}

tmux_socket_path_from_env() {
    local tmux_env="${TMUX:-}"
    if [[ -n "$tmux_env" ]]; then
        printf '%s' "${tmux_env%%,*}"
    fi
}

registry_file_matches_tmux_metadata() {
    local path="$1"
    local tmux_pane_id="$2"
    local tmux_socket_path="$3"

    [[ -f "$path" ]] || return 1

    if [[ -n "$tmux_pane_id" ]]; then
        grep -q "\"tmux_pane_id\":\"$(json_escape "$tmux_pane_id")\"" "$path" 2>/dev/null || return 1
    fi
    if [[ -n "$tmux_socket_path" ]]; then
        grep -q "\"tmux_socket_path\":\"$(json_escape "$tmux_socket_path")\"" "$path" 2>/dev/null || return 1
    fi
    return 0
}

write_registry_file() {
    local path="$1"
    local workspace_id="$2"
    local session_id="$3"
    local panel_id="$4"
    local pid="$5"
    local cwd="$6"
    local created_at="$7"
    local tmp_path=""
    local tmux_pane_id=""
    local tmux_socket_path=""
    local tmux_fields=""

    tmux_pane_id="$(tmux_pane_id_from_env)"
    tmux_socket_path="$(tmux_socket_path_from_env)"

    if [[ -n "$tmux_pane_id" ]]; then
        tmux_fields+=",\"tmux_pane_id\":\"$(json_escape "$tmux_pane_id")\""
    fi
    if [[ -n "$tmux_socket_path" ]]; then
        tmux_fields+=",\"tmux_socket_path\":\"$(json_escape "$tmux_socket_path")\""
    fi

    mkdir -p "$REGISTRY_ROOT"
    tmp_path="$(mktemp "$REGISTRY_ROOT/.claude-registry.XXXXXX")"
    {
        printf '{"version":1,"vendor":"claude","workspace_id":"%s","session_id":"%s","panel_id":"%s","pid":%s,"cwd":"%s","created_at":"%s"%s}\n' \
            "$(json_escape "$workspace_id")" \
            "$(json_escape "$session_id")" \
            "$(json_escape "$panel_id")" \
            "$pid" \
            "$(json_escape "$cwd")" \
            "$(json_escape "$created_at")" \
            "$tmux_fields" > "$tmp_path"
        mv -f "$tmp_path" "$path"
    } || {
        rm -f "$tmp_path"
        return 1
    }
}

read_session_id_from_registry_file() {
    local path="$1"
    [[ -f "$path" ]] || return 1
    sed -n 's/.*"session_id":"\([^"]*\)".*/\1/p' "$path" | head -n1
}

find_registry_file_for_pid() {
    local pid="$1"
    local path=""
    shopt -s nullglob
    for path in "$REGISTRY_ROOT"/claude-*.json; do
        if grep -q "\"pid\":$pid" "$path" 2>/dev/null; then
            printf '%s' "$path"
            shopt -u nullglob
            return 0
        fi
    done
    shopt -u nullglob
    return 1
}

monitor_registry_file() {
    local pid="$1"
    local workspace_id="$2"
    local panel_id="$3"
    local cwd="$4"
    local created_at="$5"
    local current_session_id="${6:-}"
    local registry_file="${7:-}"

    while kill -0 "$pid" 2>/dev/null; do
        if [[ -z "$current_session_id" || -z "$registry_file" || ! -f "$registry_file" ]]; then
            local discovered_registry=""
            if discovered_registry="$(find_registry_file_for_pid "$pid")"; then
                registry_file="$discovered_registry"
                local discovered_session_id=""
                discovered_session_id="$(read_session_id_from_registry_file "$registry_file" || true)"
                if [[ -n "$discovered_session_id" ]]; then
                    current_session_id="$discovered_session_id"
                fi
            fi
        fi

        if [[ -n "$current_session_id" ]]; then
            if [[ -z "$registry_file" ]]; then
                registry_file="$REGISTRY_ROOT/claude-$current_session_id.json"
            fi
            local tmux_pane_id=""
            local tmux_socket_path=""
            tmux_pane_id="$(tmux_pane_id_from_env)"
            tmux_socket_path="$(tmux_socket_path_from_env)"
            if [[ ! -f "$registry_file" ]] || ! registry_file_matches_tmux_metadata "$registry_file" "$tmux_pane_id" "$tmux_socket_path"; then
                write_registry_file "$registry_file" "$workspace_id" "$current_session_id" "$panel_id" "$pid" "$cwd" "$created_at"
            fi
        fi
        sleep 2
    done

    if [[ -n "$registry_file" ]]; then
        rm -f "$registry_file"
    fi
}

shell_quote() {
    local s="${1-}"
    s=${s//\'/\'\\\'\'}
    printf "'%s'" "$s"
}

build_hook_command() {
    local event="$1"
    local prefix="${2:-}"
    local tidey_bin_path="$HOOK_DIR/tidey"
    local pane_helper_path="$HOOK_DIR/tidey-tmux-pane-identity"
    local script=""

    if [[ -n "$prefix" ]]; then
        script+="$prefix; "
    fi

    script+=". $(shell_quote "$pane_helper_path"); tidey_hydrate_tmux_pane_identity; "
    script+="exec $(shell_quote "$tidey_bin_path") claude-hook $(shell_quote "$event")"

    printf '/bin/sh -c %s' "$(shell_quote "$script")"
}

# Find the real claude binary, skipping our own directory.
find_real_claude() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/claude" ]] && printf '%s' "$d/claude" && return 0
    done
    return 1
}

# Pass through if not in a Tidey terminal or socket is unavailable.
if [[ -z "${TIDEY_SOCKET_PATH:-}" || ! -S "${TIDEY_SOCKET_PATH:-}" ]]; then
    REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }
    exec "$REAL_CLAUDE" "$@"
fi

REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }

# Pass through subcommands that don't support hooks.
case "${1:-}" in
    mcp|config|api-key) exec "$REAL_CLAUDE" "$@" ;;
esac

find_explicit_session_id() {
    local args=("$@")
    local i=0
    while [[ $i -lt ${#args[@]} ]]; do
        local arg="${args[$i]}"
        case "$arg" in
            --session-id=*)
                printf '%s' "${arg#--session-id=}"
                return 0
                ;;
            --resume=*)
                printf '%s' "${arg#--resume=}"
                return 0
                ;;
            --continue=*)
                printf '%s' "${arg#--continue=}"
                return 0
                ;;
            --session-id|--resume|--continue|-r|-c)
                if [[ $((i + 1)) -lt ${#args[@]} ]]; then
                    local next="${args[$((i + 1))]}"
                    if [[ "$next" != -* ]]; then
                        printf '%s' "$next"
                        return 0
                    fi
                fi
                ;;
        esac
        i=$((i + 1))
    done
    return 1
}

has_implicit_resume_flag() {
    local args=("$@")
    local i=0
    while [[ $i -lt ${#args[@]} ]]; do
        local arg="${args[$i]}"
        case "$arg" in
            --resume|--continue|-r|-c)
                if [[ $((i + 1)) -ge ${#args[@]} ]]; then
                    return 0
                fi
                local next="${args[$((i + 1))]}"
                if [[ "$next" == -* ]]; then
                    return 0
                fi
                ;;
        esac
        i=$((i + 1))
    done
    return 1
}

SESSION_ID=""
if ! SESSION_ID="$(find_explicit_session_id "$@")"; then
    if has_implicit_resume_flag "$@"; then
        SESSION_ID=""
    else
        SESSION_ID="$(uuidgen | tr '[:upper:]' '[:lower:]')"
        set -- --session-id "$SESSION_ID" "$@"
    fi
fi
tidey_hydrate_tmux_pane_identity

# Build hooks settings JSON.
# Claude Code merges --settings additively with the user's own settings.json.
SESSION_HOOK_PREFIX="export TIDEY_CLAUDE_WRAPPER_PID=$(shell_quote "$$"); export TIDEY_CLAUDE_WRAPPER_CWD=$(shell_quote "$PWD")"
SESSION_START_CMD="$(json_escape "$(build_hook_command "session-start" "$SESSION_HOOK_PREFIX")")"
NOTIFICATION_CMD="$(json_escape "$(build_hook_command "notification")")"
STOP_CMD="$(json_escape "$(build_hook_command "stop")")"
SESSION_END_CMD="$(json_escape "$(build_hook_command "session-end" "$SESSION_HOOK_PREFIX")")"
PROMPT_SUBMIT_CMD="$(json_escape "$(build_hook_command "prompt-submit")")"
HOOKS_JSON="{\"hooks\":{\"SessionStart\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$SESSION_START_CMD\",\"timeout\":10}]}],\"Notification\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$NOTIFICATION_CMD\",\"timeout\":10}]}],\"Stop\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$STOP_CMD\",\"timeout\":10}]}],\"SessionEnd\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$SESSION_END_CMD\",\"timeout\":1}]}],\"UserPromptSubmit\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$PROMPT_SUBMIT_CMD\",\"timeout\":10}]}]}}"

REGISTRY_FILE=""
MONITOR_PID=""
if [[ -n "${TIDEY_WORKSPACE_ID:-}" && -n "$SESSION_ID" ]]; then
    REGISTRY_FILE="$REGISTRY_ROOT/claude-${SESSION_ID}.json"
    CREATED_AT="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    write_registry_file "$REGISTRY_FILE" "$TIDEY_WORKSPACE_ID" "$SESSION_ID" "${TIDEY_PANEL_ID:-}" "$$" "$PWD" "$CREATED_AT"
else
    CREATED_AT="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
fi

if [[ -n "${TIDEY_WORKSPACE_ID:-}" ]]; then
    monitor_registry_file "$$" "$TIDEY_WORKSPACE_ID" "${TIDEY_PANEL_ID:-}" "$PWD" "$CREATED_AT" "$SESSION_ID" "$REGISTRY_FILE" &
    MONITOR_PID="$!"
fi

cleanup() {
    if [[ -n "${MONITOR_PID:-}" ]]; then
        kill "$MONITOR_PID" 2>/dev/null || true
        wait "$MONITOR_PID" 2>/dev/null || true
    fi
    if [[ -n "${REGISTRY_FILE:-}" ]]; then
        rm -f "$REGISTRY_FILE"
    fi
}

trap cleanup EXIT

"$REAL_CLAUDE" --settings "$HOOKS_JSON" "$@"
